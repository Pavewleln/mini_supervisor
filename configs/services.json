{
  "services": [
    {
      "name": "logger",
      "command": "/bin/sh",
      "args": ["-c", "echo first; sleep 1; echo second; echo err >&2"],
      "restart": false,
      "max_restarts": 0
    },
    {
      "name": "bad-worker",
      "command": "/bin/sh",
      "args": ["-c", "exit 42"],
      "restart": true,
      "max_restarts": 3
    },
    {
      "name": "long-tree",
      "command": "/bin/sh",
      "args": ["-c", "sleep 30 & sleep 30; wait"],
      "restart": false,
      "max_restarts": 0
    },
    {
      "name": "stubborn",
      "command": "/bin/sh",
      "args": ["-c", "trap '' TERM; sleep 30"],
      "restart": false,
      "max_restarts": 0
    }
  ]
}
